# Copy this file to .env and replace placeholder values.
# Used by local Netlify dev / Node runtime.

ADMIN_PASSWORD=change_me_to_a_strong_password

FIREBASE_PROJECT_ID=biometric-supplies-tracker
FIREBASE_DATABASE_URL=https://biometric-supplies-tracker-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@biometric-supplies-tracker.iam.gserviceaccount.com

# Paste your Firebase service-account `private_key` here.
# Keep it in one line with \n breaks (this app converts \n -> newlines automatically).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_YOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Optional alternative if your platform supports only plain values:
# FIREBASE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t...

# Optional: shared secret for ESP32 scan endpoint (/api/students/scan)
ESP32_DEVICE_KEY=change_me_device_secret
